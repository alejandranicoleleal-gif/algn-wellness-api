{
  "version": 2,
  "functions": {
    "api/assess.js": {
      "maxDuration": 30
    }
  },
  "static": {
    "outputDirectory": "public"
  },
  "routes": [
    { "src": "/api/assess", "dest": "/api/assess" },
    { "src": "/app.jsx", "dest": "/public/app.jsx" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
